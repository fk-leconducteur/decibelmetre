<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=1920">
<title>Decibelmetre Pro — SPL-9000</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Oswald:wght@300;400;600&display=swap');
  *{margin:0;padding:0;box-sizing:border-box;}
  body{width:100%;background:#080b0f;font-family:'Share Tech Mono',monospace;color:#e0e0e0;}
  .tabs{display:flex;background:#0d1015;border-bottom:1px solid #1a2030;}
  .tab{padding:10px 24px;font-size:12px;letter-spacing:2px;color:#556;cursor:pointer;border-bottom:2px solid transparent;transition:all .15s;text-transform:uppercase;}
  .tab.active{color:#00bcd4;border-bottom-color:#00bcd4;}
  .brand-bar{width:100%;background:#111418;border-bottom:1px solid #1e2530;padding:8px 24px;display:flex;align-items:center;justify-content:space-between;}
  .status-led{width:8px;height:8px;border-radius:50%;background:#00ff88;animation:blink 1.2s ease-in-out infinite;}
  @keyframes blink{0%,100%{opacity:1;}50%{opacity:.3;}}
  .display-area{width:100%;min-height:320px;display:flex;flex-direction:column;padding:16px 20px 10px;gap:10px;position:relative;overflow:hidden;}
  .bg-layer{position:absolute;top:0;left:0;right:0;bottom:0;z-index:0;background-size:cover;background-position:center;}
  .bg-overlay{position:absolute;top:0;left:0;right:0;bottom:0;z-index:1;}
  .dc{position:relative;z-index:2;width:100%;display:flex;flex-direction:column;gap:10px;}
  .scanlines{position:absolute;top:0;left:0;right:0;bottom:0;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,.04) 2px,rgba(0,0,0,.04) 4px);pointer-events:none;z-index:10;}
  .db-value{font-family:'Oswald',sans-serif;font-size:100px;font-weight:600;letter-spacing:-2px;line-height:.9;transition:color .15s;min-width:230px;text-align:right;}
  .db-unit{font-family:'Oswald',sans-serif;font-size:28px;font-weight:300;color:#556;margin-bottom:10px;letter-spacing:2px;}
  .level-label{font-family:'Oswald',sans-serif;font-size:18px;font-weight:300;letter-spacing:6px;text-transform:uppercase;text-align:center;transition:color .2s;min-height:26px;}
  .meter-section{width:100%;}
  .scale-labels{display:flex;justify-content:space-between;padding:0 2px;margin-bottom:3px;}
  .scale-labels span{font-size:10px;color:#445;}
  .bar-container{width:100%;height:36px;background:#0d1015;border:1px solid #1a2030;border-radius:3px;overflow:hidden;position:relative;}
  .bar-segments{display:flex;height:100%;gap:2px;padding:3px;}
  .seg{flex:1;border-radius:2px;transition:opacity .05s;}
  .seg.off{opacity:.08;}.seg.on{opacity:1;}
  .seg.green{background:#00e676;}.seg.yellow{background:#ffea00;}.seg.orange{background:#ff9100;}.seg.red{background:#ff1744;}
  .peak-hold{position:absolute;top:3px;bottom:3px;width:3px;background:#fff;border-radius:1px;transition:left .1s;}
  .ch-bars{display:flex;gap:6px;margin-top:5px;}
  .ch-bar{flex:1;height:16px;background:#0d1015;border:1px solid #1a2030;border-radius:2px;overflow:hidden;position:relative;}
  .ch-fill{height:100%;transition:width .08s;border-radius:2px;}
  .ch-label{position:absolute;right:5px;top:50%;transform:translateY(-50%);font-size:9px;color:rgba(255,255,255,.5);letter-spacing:1px;}
  .stats-row{display:flex;gap:14px;justify-content:center;}
  .stat-box{background:#0d1015;border:1px solid #1a2030;border-radius:4px;padding:6px 14px;text-align:center;min-width:75px;}
  .stat-label{font-size:10px;color:#445;letter-spacing:2px;margin-bottom:2px;}
  .stat-value{font-size:17px;color:#7a8fa0;}
  .stat-value.peak{color:#ff4d4d;}.stat-value.avg{color:#00bcd4;}
  .control-panel{width:100%;background:#0d1015;border-top:1px solid #1a2030;padding:12px 20px;display:flex;align-items:center;gap:14px;flex-wrap:wrap;}
  .ctrl-group{display:flex;flex-direction:column;gap:4px;flex:1;min-width:110px;}
  .ctrl-label{font-size:10px;color:#445;letter-spacing:2px;text-transform:uppercase;}
  .ctrl-row{display:flex;align-items:center;gap:7px;}
  input[type=range]{flex:1;height:4px;-webkit-appearance:none;background:#1a2030;border-radius:2px;outline:none;cursor:pointer;}
  input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:16px;height:16px;border-radius:50%;background:#00bcd4;border:2px solid #003a45;cursor:pointer;}
  .ctrl-val{font-size:13px;color:#00bcd4;min-width:44px;text-align:right;}
  .btn-group{display:flex;gap:5px;flex-wrap:wrap;}
  .btn{background:#111620;border:1px solid #2a3545;color:#8899aa;padding:6px 12px;border-radius:4px;font-family:'Share Tech Mono',monospace;font-size:11px;letter-spacing:1px;cursor:pointer;text-transform:uppercase;transition:all .15s;}
  .btn:hover{background:#1a2535;color:#ccd;border-color:#445;}
  .btn.active{background:#00bcd4;color:#003;border-color:#00bcd4;}
  .btn.danger{border-color:#ff4444;color:#ff6666;}
  .btn.danger:hover{background:#ff1744;color:#fff;}
  .btn.panne{border-color:#ff00ff;color:#ff00ff;font-size:10px;}
  .btn.panne:hover{background:#ff00ff;color:#000;}
  .btn.panne.active{background:#ff00ff;color:#000;border-color:#ff00ff;}
  .btn.launch{background:#1a3020;border-color:#00e676;color:#00e676;font-size:12px;padding:8px 16px;}
  .btn.launch:hover{background:#00e676;color:#003;}
  .divider{width:1px;background:#1a2030;align-self:stretch;flex-shrink:0;}
  .needle-wrap{position:relative;width:220px;height:95px;flex-shrink:0;}
  .config-panel{background:#0a0c0f;padding:14px 20px;border-top:1px solid #1a2030;}
  .config-title{font-size:10px;color:#445;letter-spacing:3px;text-transform:uppercase;margin-bottom:10px;}
  .config-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:7px;}
  .config-item{display:flex;flex-direction:column;gap:3px;}
  .config-item label{font-size:10px;letter-spacing:1px;}
  .config-item input[type=text]{background:#111620;border:1px solid #2a3545;color:#cdd;padding:5px 8px;border-radius:4px;font-family:'Share Tech Mono',monospace;font-size:11px;outline:none;width:100%;}
  .config-item input[type=text]:focus{border-color:#00bcd4;}
  .lcfg label{font-size:10px;color:#556;letter-spacing:1px;margin-bottom:3px;display:block;}
  .lcfg input[type=text]{background:#111620;border:1px solid #2a3545;color:#cdd;padding:5px 8px;border-radius:4px;font-family:'Share Tech Mono',monospace;font-size:11px;outline:none;width:100%;}
  .lcfg input[type=text]:focus{border-color:#00bcd4;}
  .info-box{background:#0d1520;border:1px solid #1a3040;border-radius:6px;padding:10px 14px;font-size:12px;color:#7a9ab0;line-height:1.9;margin-bottom:12px;}
  .info-box b{color:#00bcd4;}
  .panne-overlay{display:none;position:absolute;top:0;left:0;right:0;bottom:0;z-index:20;background:#000;align-items:center;justify-content:center;flex-direction:column;gap:16px;}
  .panne-overlay.active{display:flex;}
  .panne-txt{font-family:'Oswald',sans-serif;font-size:48px;font-weight:600;letter-spacing:8px;color:#ff00ff;animation:pflic 0.4s step-end infinite;}
  .panne-sub{font-family:'Share Tech Mono',monospace;font-size:16px;letter-spacing:4px;color:#aa44aa;}
  @keyframes pflic{0%,100%{opacity:1;}50%{opacity:.2;}}
</style>
</head>
<body>

<div class="tabs">
  <div class="tab active" onclick="switchTab('ctrl')">Controle</div>
  <div class="tab" onclick="switchTab('cfg')">Personnalisation</div>
</div>

<div id="panelCtrl">
  <div class="brand-bar">
    <span style="font-family:'Oswald',sans-serif;font-size:13px;font-weight:300;letter-spacing:4px;color:#556;text-transform:uppercase;">SoundLevel Pro — SPL-9000</span>
    <div style="display:flex;align-items:center;gap:12px;">
      <button class="btn launch" onclick="openDisplay()">OUVRIR ECRAN DIFFUSION</button>
      <div class="status-led"></div>
    </div>
  </div>

  <div class="display-area" id="displayArea">
    <div class="bg-layer" id="bgLayer"></div>
    <div class="bg-overlay" id="bgOverlay" style="background:rgba(8,11,15,.72);"></div>
    <div class="dc">
      <div id="logoArea" style="display:flex;min-height:20px;"></div>
      <div style="display:flex;align-items:flex-end;gap:10px;justify-content:center;">
        <div class="db-value" id="dbValue">45</div>
        <div class="db-unit">dB</div>
      </div>
      <div class="level-label" id="levelLabel">CALME</div>
      <div class="meter-section">
        <div class="scale-labels"><span>0</span><span>20</span><span>40</span><span>60</span><span>80</span><span>100</span><span>120</span><span>140</span></div>
        <div class="bar-container"><div class="bar-segments" id="barSegs"></div><div class="peak-hold" id="peakBar"></div></div>
        <div class="ch-bars">
          <div class="ch-bar"><div class="ch-fill" id="ch1" style="background:#00e676;width:30%;"></div><div class="ch-label">L</div></div>
          <div class="ch-bar"><div class="ch-fill" id="ch2" style="background:#00e676;width:30%;"></div><div class="ch-label">R</div></div>
          <div class="ch-bar"><div class="ch-fill" id="ch3" style="background:#00bcd4;width:25%;"></div><div class="ch-label">MIC</div></div>
          <div class="ch-bar"><div class="ch-fill" id="ch4" style="background:#ff9100;width:18%;"></div><div class="ch-label">LFE</div></div>
        </div>
      </div>
      <div class="stats-row">
        <div class="stat-box"><div class="stat-label">Peak</div><div class="stat-value peak" id="peakVal">--</div></div>
        <div class="stat-box"><div class="stat-label">Moyenne</div><div class="stat-value avg" id="avgVal">--</div></div>
        <div class="stat-box"><div class="stat-label">Min</div><div class="stat-value" id="minVal" style="color:#556;">--</div></div>
        <div class="stat-box"><div class="stat-label">Max</div><div class="stat-value" id="maxVal" style="color:#ff9100;">--</div></div>
      </div>
    </div>
    <div class="panne-overlay" id="panneOverlay">
      <div class="panne-txt" id="panneTxt">EN PANNE !</div>
      <div class="panne-sub" id="panneSub">VOUS AVEZ TOUT CASSE !</div>
    </div>
    <div class="scanlines"></div>
  </div>

  <div class="control-panel">
    <div class="ctrl-group">
      <div class="ctrl-label">Niveau sonore</div>
      <div class="ctrl-row">
        <span style="font-size:11px;color:#556;">0</span>
        <input type="range" id="dbSlider" min="0" max="140" value="45" step="1">
        <span style="font-size:11px;color:#556;">140</span>
        <span class="ctrl-val" id="sliderVal">45 dB</span>
      </div>
    </div>
    <div class="divider"></div>
    <div class="ctrl-group" style="flex:0;min-width:100px;">
      <div class="ctrl-label">Fluctuation</div>
      <div class="ctrl-row">
        <input type="range" id="jitterSlider" min="0" max="12" value="3" step="1">
        <span class="ctrl-val" id="jitterVal" style="min-width:24px;">±3</span>
      </div>
    </div>
    <div class="divider"></div>
    <div style="display:flex;flex-direction:column;gap:6px;flex-shrink:0;">
      <div class="btn-group">
        <button class="btn active" id="btnAnim" onclick="toggleAnim()">ANIM ON</button>
        <button class="btn" onclick="resetStats()">RESET</button>
        <button class="btn danger" onclick="panic()">CLAP !</button>
      </div>
      <div class="btn-group">
        <button class="btn" onclick="setPreset(30)" style="font-size:10px;">SILENCE</button>
        <button class="btn" onclick="setPreset(55)" style="font-size:10px;">SALLE</button>
        <button class="btn" onclick="setPreset(85)" style="font-size:10px;">FOULE</button>
        <button class="btn" onclick="setPreset(110)" style="font-size:10px;">CONCERT</button>
        <button class="btn" style="font-size:10px;border-color:#ff4;color:#ff4;" onclick="setPreset(130)">MAX !</button>
        <button class="btn panne" id="btnPanne" onclick="togglePanne()">EN PANNE</button>
      </div>
    </div>
    <div class="divider"></div>
    <div class="needle-wrap">
      <svg width="100%" height="100%" viewBox="0 0 220 95" xmlns="http://www.w3.org/2000/svg">
        <defs><linearGradient id="ag" x1="0" y1="0" x2="1" y2="0"><stop offset="0%" stop-color="#00e676"/><stop offset="50%" stop-color="#ffea00"/><stop offset="75%" stop-color="#ff9100"/><stop offset="100%" stop-color="#ff1744"/></linearGradient></defs>
        <path d="M10 87 A100 100 0 0 1 210 87" fill="none" stroke="#1a2030" stroke-width="8" stroke-linecap="round"/>
        <path d="M10 87 A100 100 0 0 1 210 87" fill="none" stroke="url(#ag)" stroke-width="3" stroke-linecap="round" opacity=".6"/>
        <text x="7" y="96" fill="#334" font-size="9" font-family="monospace">0</text>
        <text x="110" y="12" fill="#334" font-size="9" font-family="monospace" text-anchor="middle">70</text>
        <text x="213" y="96" fill="#334" font-size="9" font-family="monospace" text-anchor="end">140</text>
        <line id="needle" x1="110" y1="87" x2="58" y2="30" stroke="#fff" stroke-width="2" stroke-linecap="round"/>
        <circle cx="110" cy="87" r="5" fill="#1a2030" stroke="#556" stroke-width="1"/>
        <circle cx="110" cy="87" r="2.5" fill="#00bcd4"/>
      </svg>
    </div>
  </div>
</div>

<div id="panelCfg" style="display:none;">
  <div class="config-panel" style="border-top:none;">
    <div class="info-box">
      <b>Mode d'emploi :</b><br>
      1. Configure ici les labels, logo, fond — puis <b>APPLIQUER</b><br>
      2. Onglet <b>CONTROLE</b> → bouton vert <b>OUVRIR ECRAN DIFFUSION</b><br>
      3. Deplace la fenetre sur ton grand ecran → <b>F11</b> plein ecran 1920x1080<br>
      4. Pilote depuis cet onglet — tout se synchronise en temps reel
    </div>
    <div class="config-title">Labels selon niveau — et message EN PANNE</div>
    <div class="config-grid" id="configGrid"></div>
    <div style="margin-top:14px;display:flex;gap:18px;flex-wrap:wrap;">
      <div style="flex:1;min-width:190px;">
        <div class="config-title" style="margin-bottom:8px;">Logo (haut gauche)</div>
        <div class="lcfg" style="margin-bottom:7px;"><label>URL image du logo</label><input type="text" id="logoUrl" placeholder="https://monsite.com/logo.png" oninput="previewLogo()"></div>
        <div class="lcfg"><label>Ou nom / texte evenement</label><input type="text" id="logoText" placeholder="NOM EVENEMENT" oninput="previewLogo()"></div>
        <div style="margin-top:7px;display:flex;align-items:center;gap:8px;">
          <span style="font-size:10px;color:#445;">Apercu :</span>
          <div id="logoPreview" style="background:#0d1015;border:1px solid #2a3545;border-radius:4px;padding:5px 8px;min-width:70px;min-height:28px;display:flex;align-items:center;"><span style="font-size:9px;color:#445;">--</span></div>
        </div>
      </div>
      <div style="flex:1;min-width:190px;">
        <div class="config-title" style="margin-bottom:8px;">Fond d'ecran</div>
        <div class="lcfg" style="margin-bottom:7px;"><label>URL image de fond</label><input type="text" id="bgUrl" placeholder="https://..." oninput="updateBg()"></div>
        <div class="lcfg"><label>Opacite du voile</label>
          <div class="ctrl-row"><input type="range" min="0" max="95" value="72" step="1" id="bgOpacity" oninput="updateBgOpacity()"><span class="ctrl-val" id="bgOpVal" style="min-width:32px;">72%</span></div>
        </div>
      </div>
    </div>
    <div style="margin-top:12px;display:flex;gap:8px;">
      <button class="btn launch" onclick="applyConfig()">APPLIQUER</button>
      <button class="btn" onclick="resetConfig()">REINITIALISER</button>
    </div>
  </div>
</div>

<script>
const NUM=60;
let targetDb=45,currentDb=45,peakDb=0,sMin=999,sMax=0,avgSum=0,avgCount=0;
let animOn=true,panicTmt=null,bgOpacityVal=72,panneMode=false;
let displayWin=null;
let panneLabel='EN PANNE !', panneSublabel='VOUS AVEZ TOUT CASSE !';

const defaultLevels=[
  {max:20,label:'SILENCE ABSOLU',color:'#00e676'},
  {max:30,label:'CHUCHOTEMENT',color:'#00e676'},
  {max:45,label:'CALME',color:'#00e676'},
  {max:60,label:'CONVERSATION',color:'#7ce87c'},
  {max:70,label:'AMBIANCE',color:'#c8e676'},
  {max:80,label:'ANIME !',color:'#ffea00'},
  {max:90,label:'BRUYANT',color:'#ffc107'},
  {max:100,label:'TRES FORT',color:'#ff9100'},
  {max:110,label:'FOULE EN DELIRE',color:'#ff5722'},
  {max:120,label:'CONCERT ROCK',color:'#ff3d00'},
  {max:130,label:'DANGER AUDITIF',color:'#ff1744'},
  {max:999,label:'EXTREME !!!',color:'#ff0044'},
];
let levels=defaultLevels.map(l=>({...l}));

function buildSegs(){
  const c=document.getElementById('barSegs');c.innerHTML='';
  for(let i=0;i<NUM;i++){const s=document.createElement('div');s.className='seg off';const p=(i/NUM)*140;s.classList.add(p<60?'green':p<85?'yellow':p<105?'orange':'red');c.appendChild(s);}
}

function buildConfigGrid(){
  const g=document.getElementById('configGrid');g.innerHTML='';
  levels.forEach((lv,i)=>{
    const w=document.createElement('div');w.className='config-item';
    const l=document.createElement('label');l.textContent=`${lv.max===999?'130-140':((i===0?0:levels[i-1].max)+1)+'-'+lv.max} dB`;l.style.color=lv.color;
    const inp=document.createElement('input');inp.type='text';inp.value=lv.label;inp.dataset.idx=i;inp.placeholder=defaultLevels[i].label;
    w.appendChild(l);w.appendChild(inp);g.appendChild(w);
  });
  const sep=document.createElement('div');sep.style.cssText='grid-column:1/-1;border-top:1px solid #1a2030;padding-top:10px;margin-top:4px;';
  const st=document.createElement('div');st.style.cssText='font-size:10px;color:#ff00ff;letter-spacing:3px;text-transform:uppercase;margin-bottom:8px;';st.textContent='Texte mode EN PANNE';
  sep.appendChild(st);g.appendChild(sep);
  [{id:'panneInp1',lab:'Titre (grand)',val:panneLabel,ph:'EN PANNE !'},{id:'panneInp2',lab:'Sous-titre',val:panneSublabel,ph:'VOUS AVEZ TOUT CASSE !'}].forEach(x=>{
    const w=document.createElement('div');w.className='config-item';
    const l=document.createElement('label');l.textContent=x.lab;l.style.color='#aa44aa';
    const inp=document.createElement('input');inp.type='text';inp.id=x.id;inp.value=x.val;inp.placeholder=x.ph;
    w.appendChild(l);w.appendChild(inp);g.appendChild(w);
  });
}

function updateDisplay(db){
  if(panneMode)return;
  db=Math.max(0,Math.min(140,db));currentDb=db;
  const lv=levels.find(l=>db<=l.max)||levels[levels.length-1];
  const segs=document.querySelectorAll('#barSegs .seg');
  const act=Math.round((db/140)*NUM);
  segs.forEach((s,i)=>{s.classList.toggle('on',i<act);s.classList.toggle('off',i>=act);});
  document.getElementById('peakBar').style.left=`calc(${(peakDb/140)*100}% - 1px)`;
  document.getElementById('dbValue').textContent=Math.round(db);
  document.getElementById('dbValue').style.color=lv.color;
  document.getElementById('levelLabel').textContent=lv.label;
  document.getElementById('levelLabel').style.color=lv.color;
  const cf=v=>v<60?'#00e676':v<85?'#ffea00':v<105?'#ff9100':'#ff1744';
  document.getElementById('ch1').style.width=Math.min(100,(db+(Math.random()*6-3))/140*100)+'%';
  document.getElementById('ch2').style.width=Math.min(100,(db+(Math.random()*6-3))/140*100)+'%';
  document.getElementById('ch3').style.width=Math.min(100,(db*.85+(Math.random()*4-2))/140*100)+'%';
  document.getElementById('ch4').style.width=Math.min(100,(db*.6+(Math.random()*8-4))/140*100)+'%';
  document.getElementById('ch1').style.background=cf(db);
  document.getElementById('ch2').style.background=cf(db);
  const angle=-130+(db/140)*260,rad=(angle*Math.PI)/180;
  const nx=110+Math.sin(rad)*60,ny=87-Math.cos(rad)*60;
  const n=document.getElementById('needle');n.setAttribute('x2',nx.toFixed(1));n.setAttribute('y2',ny.toFixed(1));n.setAttribute('stroke',lv.color);
  if(db>peakDb){peakDb=db;document.getElementById('peakVal').textContent=Math.round(peakDb)+' dB';}
  if(db<sMin){sMin=db;document.getElementById('minVal').textContent=Math.round(db)+' dB';}
  if(db>sMax){sMax=db;document.getElementById('maxVal').textContent=Math.round(db)+' dB';}
  avgSum+=db;avgCount++;
  if(avgCount%10===0)document.getElementById('avgVal').textContent=Math.round(avgSum/avgCount)+' dB';
  sendToDisplay({type:'spl',db:db,pk:peakDb});
}

function togglePanne(){
  panneMode=!panneMode;
  document.getElementById('btnPanne').classList.toggle('active',panneMode);
  document.getElementById('panneOverlay').classList.toggle('active',panneMode);
  sendToDisplay({type:'panne',active:panneMode,label:panneLabel,sub:panneSublabel});
}

function tick(){
  if(animOn&&!panneMode){const j=parseFloat(document.getElementById('jitterSlider').value);updateDisplay(targetDb+(Math.random()*2-1)*j+Math.sin(Date.now()/300)*1.5);}
  requestAnimationFrame(tick);
}

function toggleAnim(){animOn=!animOn;const b=document.getElementById('btnAnim');b.textContent=animOn?'ANIM ON':'ANIM OFF';b.classList.toggle('active',animOn);if(!animOn)updateDisplay(targetDb);}
function resetStats(){peakDb=0;sMin=999;sMax=0;avgSum=0;avgCount=1;['peakVal','avgVal','minVal','maxVal'].forEach(id=>document.getElementById(id).textContent='--');}
function panic(){if(panneMode)return;const o=targetDb;const sp=Math.min(140,targetDb+28+Math.random()*14);targetDb=sp;document.getElementById('dbSlider').value=sp;document.getElementById('sliderVal').textContent=Math.round(sp)+' dB';clearTimeout(panicTmt);panicTmt=setTimeout(()=>{targetDb=o;document.getElementById('dbSlider').value=o;document.getElementById('sliderVal').textContent=Math.round(o)+' dB';},1200);}
function setPreset(v){if(panneMode)return;targetDb=v;document.getElementById('dbSlider').value=v;document.getElementById('sliderVal').textContent=v+' dB';if(!animOn)updateDisplay(v);}
