function upd(db,pk){
  db=Math.max(0,Math.min(140,db));
  var l=lv.find(function(x){return db<=x.max;})||lv[lv.length-1];
  document.querySelectorAll('.seg').forEach(function(s,i){var a=Math.round((db/140)*N);s.classList.toggle('on',i<a);s.classList.toggle('off',i>=a);});
