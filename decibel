function applyConfig(){
  document.querySelectorAll('#configGrid input[type=text][data-idx]').forEach(inp=>{const i=parseInt(inp.dataset.idx);if(inp.value.trim())levels[i].label=inp.value.trim().toUpperCase();});
  const p1=document.getElementById('panneInp1'),p2=document.getElementById('panneInp2');
  if(p1&&p1.value.trim())panneLabel=p1.value.trim().toUpperCase();
  if(p2&&p2.value.trim())panneSublabel=p2.value.trim().toUpperCase();
  document.getElementById('panneTxt').textContent=panneLabel;
  document.getElementById('panneSub').textContent=panneSublabel;
  applyLogoAndBg();updateDisplay(currentDb);
}

function applyLogoAndBg(){
  const url=document.getElementById('logoUrl').value.trim();
  const txt=document.getElementById('logoText').value.trim();
  const area=document.getElementById('logoArea');
  area.innerHTML='';
  if(url){const img=document.createElement('img');img.src=url;img.style.cssText='max-height:44px;max-width:160px;object-fit:contain;';area.appendChild(img);}
  else if(txt){const sp=document.createElement('span');sp.textContent=txt.toUpperCase();sp.style.cssText='font-family:Oswald,sans-serif;font-size:16px;font-weight:600;letter-spacing:4px;color:#fff;';area.appendChild(sp);}
  const bgUrl=document.getElementById('bgUrl').value.trim();
  document.getElementById('bgLayer').style.backgroundImage=bgUrl?`url(${bgUrl})`:'none';
  document.getElementById('bgOverlay').style.background=`rgba(8,11,15,${bgOpacityVal/100})`;
}

function previewLogo(){
  const url=document.getElementById('logoUrl').value.trim(),txt=document.getElementById('logoText').value.trim(),p=document.getElementById('logoPreview');
  p.innerHTML='';
  if(url){const img=document.createElement('img');img.src=url;img.style.cssText='max-height:26px;max-width:110px;object-fit:contain;';p.appendChild(img);}
  else if(txt)p.innerHTML=`<span style="font-size:11px;color:#ccd;font-family:monospace;letter-spacing:2px;">${txt.substring(0,14).toUpperCase()}</span>`;
  else p.innerHTML='<span style="font-size:9px;color:#445;">--</span>';
}

function updateBg(){const u=document.getElementById('bgUrl').value.trim();document.getElementById('bgLayer').style.backgroundImage=u?`url(${u})`:'none';document.getElementById('bgOverlay').style.background=`rgba(8,11,15,${bgOpacityVal/100})`;}
function updateBgOpacity(){bgOpacityVal=parseInt(document.getElementById('bgOpacity').value);document.getElementById('bgOpVal').textContent=bgOpacityVal+'%';document.getElementById('bgOverlay').style.background=`rgba(8,11,15,${bgOpacityVal/100})`;}
