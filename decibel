  L.textContent=l.label;L.style.color=l.color;
  PP.style.left='calc('+(pk/140*100)+'% - 2px)';
  var cf=function(v){return v<60?'#00e676':v<85?'#ffea00':v<105?'#ff9100':'#ff1744';};
  document.getElementById('c1').style.width=Math.min(100,(db+(Math.random()*6-3))/140*100)+'%';document.getElementById('c1').style.background=cf(db);
